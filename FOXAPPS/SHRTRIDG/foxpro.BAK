SYS(3050,1,VAL(SYS(1001)))

SET DEFAULT TO W:\FOXAPPS\
OPEN DATABASE W:\FOXAPPS\SHORTDATA SHARED

**DO w:\foxapps\tbsave.prg
*DO TBSAVE.PRG

PUBLIC CMENU

*!*	CMENU = "BETSY" 
*RDY
*!*	CMENU = "ORDRNTRY" 
CMENU = "SUPERVISOR" 

** SET ESCAPE OFF **
** DISABLE EXIT HOTKEY **
ON KEY LABEL ESCAPE DO NOESCAPE
ON KEY LABEL ALT+E DO NOEXIT 
ON KEY LABEL F1  DO NOEXIT

** SHOW ERROR MESSAGE ON ERRORS **
*!*	ON ERROR DO W:\FOXAPPS\SHRTRIDG\ERR_FIX

** SET DEFAULT SETTINGS **
SET EXCLUSIVE OFF
SET BELL OFF
SET TALK OFF
SET RESOURCE OFF 

IF VERSION(5) = 600 
	DEFINE WINDOW HIDECOM FROM 1,1 TO 3,3
	ACTIVATE WINDOW COMMAND IN HIDECOM
	DO BETSY.MPR
	RETURN
ENDIF	

SET STEP ON 	

KEYBOARD '{ALT+H}'

*!*	DO SHRTRIDG\BETSY.MPR
*!*	DO SHRTRIDG\ordrntry.MPR
DO SUPERVISOR\SUPERVISOR.MPR
READ EVENTS

KEYBOARD '{ALT+H}'   

*SET SKIP OF PAD Hide OF _MSYSMENU .T.

PROCEDURE NOESCAPE
   ESCAPE=""
ENDPROC  

PROCEDURE NOEXIT
	RETURN
ENDPROC 
   












PROCEDURE CompanySearchSQL  
	LPARAMETERS cCOID, cCONAME, cCITY, cSTATE, cZIP, cCOUNTRY, cAREA, cPHONE,  cFIRSTNAME, cLASTNAME, cAREACODE, cPHONENO, cSERIALNO, cSORTCOLUMN, cSORTORDER, cSecondSearch   
	SET EXACT OFF 	
		
	DO CASE 		
		CASE  EMPTY(cLASTNAME) AND EMPTY(cFIRSTNAME) AND EMPTY(cAREACODE) AND EMPTY(cPHONENO) 
					
			IF EMPTY(cSERIALNO)	
					cSQL = "SELECT DISTINCT CO_ID, CO_NAME, S_ADDR1, S_ADDR2, S_CITY, S_STATE, S_ZIP, S_COUNTRY,  B_ADDR1, B_ADDR2,  B_CITY, B_STATE, B_ZIP, B_COUNTRY " +   ;
			        	"FROM COMPANY WHERE  NOT DELETED() "
					
					IF !EMPTY(cCOID)
						cSQL = cSQL + "AND CO_ID = '" + ALLTRIM(cCOID) +"' AND !EMPTY(CO_ID) "
					ENDIF
					IF !EMPTY(cCONAME)
						cSQL = cSQL + 'AND ALLTRIM(CO_NAME) = "' + ALLTRIM(cCONAME) +'" AND !EMPTY(CO_NAME) '
					ENDIF
					IF !EMPTY(cCITY)
						cSQL = cSQL + "AND ALLTRIM(S_CITY) = '" + ALLTRIM(cCITY) +"' AND !EMPTY(S_CITY) "
					ENDIF
					IF !EMPTY(cSTATE)
						cSQL = cSQL + "AND ALLTRIM(S_STATE) = '" + ALLTRIM(cSTATE) +"' AND !EMPTY(S_STATE) "
					ENDIF
					IF !EMPTY(cZIP)
						cSQL = cSQL + "AND S_ZIP = '" + ALLTRIM(cZIP) +"' AND !EMPTY(S_ZIP) "
					ENDIF
					IF !EMPTY(cCOUNTRY)
						cSQL = cSQL + "AND ALLTRIM(S_COUNTRY) = '" + ALLTRIM(cCOUNTRY) +"' AND !EMPTY(S_COUNTRY) "
					ENDIF
					IF !EMPTY(cAREA)
						cSQL = cSQL + "AND ALLTRIM(S_AREACODE) = '" + ALLTRIM(cAREA) +"' AND !EMPTY(S_AREACODE) "
					ENDIF
					IF !EMPTY(cPHONE)
						cSQL = cSQL + "AND ALLTRIM(S_PHONE) = '" + ALLTRIM(cPHONE) +"' AND !EMPTY(S_PHONE) "
					ENDIF
					
					cSQL = cSQL + " ORDER BY "+cSortColumn + " " + cSORTORDER + " " + "INTO CURSOR X" 
			 ELSE
			 		cSQL = "SELECT DISTINCT C.CO_ID, C.CO_NAME, S_ADDR1, S_ADDR2, S_CITY, S_STATE, S_ZIP, S_COUNTRY,  B_ADDR1, B_ADDR2,  B_CITY, B_STATE, B_ZIP, B_COUNTRY, SERIAL_NO " +   ;
			        	"FROM COMPANY C, MODEL_NO M WHERE C.CO_ID = M.CO_ID AND NOT DELETED() "
					
					IF !EMPTY(cCOID)
						cSQL = cSQL + "AND CO_ID = '" + ALLTRIM(cCOID) +"' AND !EMPTY(CO_ID) "
					ENDIF
					IF !EMPTY(cCONAME)
						cSQL = cSQL + 'AND ALLTRIM(CO_NAME) = "' + ALLTRIM(cCONAME) +'" AND !EMPTY(CO_NAME) '
					ENDIF
					IF !EMPTY(cCITY)
						cSQL = cSQL + "AND ALLTRIM(S_CITY) = '" + ALLTRIM(cCITY) +"' AND !EMPTY(S_CITY) "
					ENDIF
					IF !EMPTY(cSTATE)
						cSQL = cSQL + "AND ALLTRIM(S_STATE) = '" + ALLTRIM(cSTATE) +"' AND !EMPTY(S_STATE) "
					ENDIF
					IF !EMPTY(cZIP)
						cSQL = cSQL + "AND S_ZIP = '" + ALLTRIM(cZIP) +"' AND !EMPTY(S_ZIP) "
					ENDIF
					IF !EMPTY(cCOUNTRY)
						cSQL = cSQL + "AND ALLTRIM(S_COUNTRY) = '" + ALLTRIM(cCOUNTRY) +"' AND !EMPTY(S_COUNTRY) "
					ENDIF
					IF !EMPTY(cAREA)
						cSQL = cSQL + "AND ALLTRIM(S_AREACODE) = '" + ALLTRIM(cAREA) +"' AND !EMPTY(S_AREACODE) "
					ENDIF
					IF !EMPTY(cPHONE)
						cSQL = cSQL + "AND ALLTRIM(S_PHONE) = '" + ALLTRIM(cPHONE) +"' AND !EMPTY(S_PHONE) "
					ENDIF
					IF !EMPTY(SERIALNO)
						cSQL = cSQL + "AND ALLTRIM(SERIAL_NO) == '" + ALLTRIM(cSERIALNO) +"' AND !EMPTY(SERIAL_NO) "
					ENDIF
					
					cSQL = cSQL + " ORDER BY "+cSortColumn + " " + cSORTORDER + " " + "INTO CURSOR X" 			 		
			 		
			 ENDIF				
			
		
	  				
	  	OTHERWISE
	
			cSQL = "SELECT DISTINCT C.CO_ID, C.CO_NAME, LAST_NAME, FRST_NAME, S_ADDR1, S_ADDR2, S_CITY, S_STATE, S_ZIP, S_COUNTRY, B_ADDR1, B_ADDR2, B_CITY, B_STATE, B_ZIP, B_COUNTRY " + ;
				"FROM CONTACT, COMPANY AS C " +   ;
				"WHERE C.CO_ID = CONTACT.CO_ID AND !DELETED() " 
		
			IF !EMPTY(cCOID)
				cSQL = cSQL + "AND C.CO_ID = '" + ALLTRIM(cCOID) +"' "
			ENDIF
			IF !EMPTY(cCONAME)
				cSQL = cSQL + 'AND ALLTRIM(C.CO_NAME) = "' + ALLTRIM(cCONAME) +'" AND !EMPTY(C.CO_NAME) '
			ENDIF
			IF !EMPTY(cCITY)
				cSQL = cSQL + "AND ALLTRIM(S_CITY) = '" + ALLTRIM(cCITY) +"' AND !EMPTY(S_CITY) "
			ENDIF
			IF !EMPTY(cSTATE)
				cSQL = cSQL + "AND ALLTRIM(S_STATE) = '" + ALLTRIM(cSTATE) +"' AND !EMPTY(S_STATE) "
			ENDIF
			IF !EMPTY(cZIP)
				cSQL = cSQL + "AND S_ZIP = '" + ALLTRIM(cZIP) +"' AND !EMPTY(S_ZIP) "
			ENDIF
			IF !EMPTY(cCOUNTRY)
				cSQL = cSQL + "AND ALLTRIM(S_COUNTRY) = '" + ALLTRIM(cCOUNTRY) +"' AND !EMPTY(S_COUNTRY) "
			ENDIF
			IF !EMPTY(cAREA)
				cSQL = cSQL + "AND ALLTRIM(S_AREACODE) = '" + ALLTRIM(cAREA) +"' AND !EMPTY(S_AREACODE) "
			ENDIF
			IF !EMPTY(cPHONE)
				cSQL = cSQL + "AND ALLTRIM(S_PHONE) = '" + ALLTRIM(cPHONE) +"' AND !EMPTY(S_PHONE) "
			ENDIF
			
			IF cSecondSearch = .F.
					IF !EMPTY(cLASTNAME)
						cSQL = cSQL + 'AND ALLTRIM(LAST_NAME) == "' + ALLTRIM(cLASTNAME) +'" AND !EMPTY(LAST_NAME) '
					ENDIF
					IF !EMPTY(cFIRSTNAME)
						cSQL = cSQL + 'AND ALLTRIM(FRST_NAME) == "' + ALLTRIM(cFIRSTNAME) +'" AND !EMPTY(FRST_NAME) '
					ENDIF
			ELSE
					IF !EMPTY(cLASTNAME)
						cSQL = cSQL + 'AND LEFT(ALLTRIM(LAST_NAME), 3) == "' + LEFT(ALLTRIM(cLASTNAME),3) +'" AND !EMPTY(LAST_NAME) '
					ENDIF
					IF !EMPTY(cFIRSTNAME)
						cSQL = cSQL + 'AND ALLTRIM(FRST_NAME) = "' + ALLTRIM(cFIRSTNAME) +'" AND !EMPTY(FRST_NAME) '
					ENDIF			
			ENDIF		
					
					
			IF !EMPTY(cAREACODE)
				cSQL = cSQL + "AND ALLTRIM(AREA_CODE) = '" + ALLTRIM(cAREACODE) +"' AND !EMPTY(AREA_CODE) "
			ENDIF
			IF !EMPTY(cPHONENO)
				cSQL = cSQL + "AND ALLTRIM(PHONE_NO) = '" + ALLTRIM(cPHONENO) +"' AND !EMPTY(PHONE_NO) "
			ENDIF
				
			cSQL = cSQL + " ORDER BY "+cSortColumn + " " + cSORTORDER + " " + "INTO CURSOR X" 
		  	
	  	ENDCASE


RETURN cSQL

ENDPROC



PROCEDURE OrderSearchSQL  
	LPARAMETERS cCONAME, cORDERNO, cSORTCOLUMN, cSORTORDER   
	SET EXACT OFF	
	 	
		IF CMENU = "BETSY"
			cSQL = "SELECT ORDER_NO, CO_ID, CO_NAME, ORD_DATE " +   ;
	        	   "FROM OS WHERE NOT DELETED() AND EMPTY(ship_date) AND LEN(ALLTRIM(ORDER_NO)) > 1 "
	    ELSE
	    	cSQL = "SELECT ORDER_NO, CO_ID, CO_NAME, ORD_DATE " +   ;
	        	   "FROM OS WHERE NOT DELETED() AND EMPTY(ship_date) and EMPTY(allow_edit) AND LEN(ALLTRIM(ORDER_NO)) > 1 "	    
	    ENDIF    	
			
			
		IF !EMPTY(cCONAME)
			cSQL = cSQL + 'AND ALLTRIM(CO_NAME) = "' + ALLTRIM(cCONAME) +'" AND !EMPTY(CO_NAME) '
		ENDIF
		IF !EMPTY(cORDERNO)
			cSQL = cSQL + "AND ALLTRIM(ORDER_NO) = '" + ALLTRIM(cORDERNO) +"' AND !EMPTY(ORDER_NO) "
		ENDIF		
				
		cSQL = cSQL + " ORDER BY "+cSortColumn + " " + cSORTORDER + " " + "INTO CURSOR X" 
	  				
	
RETURN cSQL

ENDPROC



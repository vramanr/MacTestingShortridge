PROCEDURE PrecheckSearchSQL  
	LPARAMETERS cORDERNO, cSERIAL,cCONAME, cDATERECEIVED, cSORTCOLUMN, cSORTORDER   
	SET EXACT OFF	
	 	
		cSQL = "SELECT ORDER_NO, SERIAL_NUM, RECVD_FROM, DATE_ENTRD " +   ;
        	"FROM PRECHECK WHERE NOT DELETED() AND EMPTY(SHIPPED) "
			
		IF !EMPTY(cCONAME)
			cSQL = cSQL + 'AND ALLTRIM(RECVD_FROM) = "' + ALLTRIM(cCONAME) +'" AND !EMPTY(RECVD_FROM) '
		ENDIF
		IF !EMPTY(cORDERNO)
			cSQL = cSQL + "AND ALLTRIM(ORDER_NO) = '" + ALLTRIM(cORDERNO) +"' AND !EMPTY(ORDER_NO) "
		ENDIF
		IF !EMPTY(cSERIAL)
			cSQL = cSQL + "AND ALLTRIM(SERIAL_NUM) = '" + ALLTRIM(cSERIAL) +"' AND !EMPTY(SERIAL_NUM) "
		ENDIF
		IF !EMPTY(cDATERECEIVED)
			cSQL = cSQL + "AND DATE_ENTRD = CTOD('" + ALLTRIM(cDATERECEIVED)+"') AND !EMPTY(DATE_ENTRD) "
		ENDIF
				
		cSQL = cSQL + " ORDER BY "+cSortColumn + " " + cSORTORDER + " " + "INTO CURSOR X" 
	  				
	
RETURN cSQL

ENDPROC


PROCEDURE OrderInfoSearchSQL  
	LPARAMETERS cCOID, cCONAME ,cORDERNO, cSERIALNO, cPONO, cINVNO, cSORTCOLUMN, cSORTORDER   
	SET EXACT OFF	
	 	
		cSQL = "SELECT I.CO_ID, I.CO_NAME, INV_NO,  I.ORDER_NO, PO_NO, SERIAL_NO, MODEL_NO  " +   ;
        	"FROM INVOICE I LEFT OUTER JOIN MODEL_NO M ON I.CO_ID = M.CO_ID AND I.ORDER_NO = M.ORDER_NO WHERE NOT DELETED() "
           
        IF !EMPTY(cCONAME)       		
       		cSQL = cSQL + 'AND I.CO_ID IN (SELECT CO_ID FROM INVOICE B WHERE B.CO_NAME = "' + cCONAME + '") '       		
			cCONAME = ""        
        ENDIF
        	
        IF !EMPTY(cCOID)
			cSQL = cSQL + "AND I.co_id = '" + cCOID +"' AND !EMPTY(I.co_id) "
		ENDIF	
			
		IF !EMPTY(cCONAME)
			cSQL = cSQL + 'AND I.co_name = "' + cCONAME +'" AND !EMPTY(I.co_name) '
		ENDIF
		IF !EMPTY(cORDERNO)
			cSQL = cSQL + "AND I.ORDER_NO = '" + cORDERNO +"' AND !EMPTY(I.ORDER_NO) "
		ENDIF
		IF !EMPTY(cPONO)
			cSQL = cSQL + "AND PO_NO = '" + cPONO + "' AND !EMPTY(PO_NO) "
		ENDIF
		IF !EMPTY(cSERIALNO)
			cSQL = cSQL + "AND SERIAL_NO = '" + cSERIALNO +"' AND !EMPTY(SERIAL_NO) "
		ENDIF
		IF !EMPTY(cINVNO)
			cSQL = cSQL + "AND INV_NO = '" + cINVNO + "' AND !EMPTY(INV_NO) "
		ENDIF
							
				
		cSQL = cSQL + " ORDER BY "+cSortColumn + " " + cSORTORDER + " " + "INTO CURSOR X" 
	  				
	
RETURN cSQL
ENDPROC


PROCEDURE InvoiceSearchSQL  
	LPARAMETERS cCOID, cCONAME ,cORDERNO, cPONO, cINVNO, cCLASS, cAMOUNT, cAMOUNTTO, cTYPE, cSORTCOLUMN, cSORTORDER   
	SET EXACT OFF	
	 	
		cSQL = "SELECT I.CO_ID, I.CO_NAME, I.ORDER_NO, I.INV_NO, I.PO_NO, AMOUNT, AMOUNT - AMT_PAID " +   ;
        	"FROM INVOICE I, AMOUNT A WHERE I.CO_ID = A.CO_ID AND I.ORDER_NO = A.ORDER_NO "         	  	
        	
        IF !EMPTY(cCOID)
			cSQL = cSQL + "AND I.co_id = '" + cCOID +"' AND !EMPTY(I.co_id) "
		ENDIF				
		IF !EMPTY(cCONAME)
			cSQL = cSQL + 'AND I.co_name = "' + cCONAME +'" AND !EMPTY(I.co_name) '
		ENDIF
		IF !EMPTY(cORDERNO)
			cSQL = cSQL + "AND I.ORDER_NO = '" + cORDERNO +"' AND !EMPTY(I.ORDER_NO) "
		ENDIF
		IF !EMPTY(cINVNO)
			cSQL = cSQL + "AND INV_NO = '" + cINVNO + "' AND !EMPTY(INV_NO) "
		ENDIF
		IF !EMPTY(cPONO)
			cSQL = cSQL + "AND PO_NO = '" + cPONO + "' AND !EMPTY(PO_NO) "
		ENDIF
		IF !EMPTY(cCLASS)
			cSQL = cSQL + "AND ORDR_CODE = '" + cCLASS + "' AND !EMPTY(ORDR_CODE) "
		ENDIF
		IF !EMPTY(cAMOUNT) AND EMPTY(cAMOUNTTO)
			cSQL = cSQL + "AND AMOUNT = " + ALLTRIM(cAMOUNT)+ " AND !EMPTY(AMOUNT) "
		ENDIF		
		IF !EMPTY(cAMOUNT) AND !EMPTY(cAMOUNTTO)
			cSQL = cSQL + "AND AMOUNT BETWEEN " + ALLTRIM(cAMOUNT) + " AND " + ALLTRIM(cAMOUNTTO)
		ENDIF
		
		DO CASE 
			CASE cTYPE = "ALL"
				cSQL = cSQL + " ORDER BY "+cSortColumn + " " + cSORTORDER + " " + " INTO CURSOR X" 			
			CASE cTYPE = "UNDER"
				cSQL = cSQL + " ORDER BY "+cSortColumn + " " + cSORTORDER + " " + "HAVING AMOUNT > AMT_PAID INTO CURSOR X" 
			CASE cTYPE = "OVER"
				cSQL = cSQL + " ORDER BY "+cSortColumn + " " + cSORTORDER + " " + "HAVING AMOUNT < AMT_PAID INTO CURSOR X" 
		ENDCASE	
				  				
	
RETURN cSQL
ENDPROC


PROCEDURE CheckSearchSQL  
	LPARAMETERS cCOID, cCONAME ,cORDERNO, cPONO, cINVNO, cCHECK, cAMOUNT, cAMOUNTTO, cSORTCOLUMN, cSORTORDER   
	SET EXACT OFF	
	 	
		cSQL = "SELECT I.CO_ID, I.CO_NAME, I.ORDER_NO, I.PO_NO, P.CHECK_NO, P.AMOUNT,  P.PAYMENT_DT " +   ;
        	"FROM INVOICE I, PAY_DTL P WHERE !DELETED() AND  I.ORDER_NO = P.ORDER_NO  "
               	
        IF !EMPTY(cCOID)
			cSQL = cSQL + "AND I.co_id = '" + cCOID +"' AND !EMPTY(I.co_id) "
		ENDIF				
		IF !EMPTY(cCONAME)
			cSQL = cSQL + 'AND I.co_name = "' + cCONAME +'" AND !EMPTY(I.co_name) '
		ENDIF
		IF !EMPTY(cORDERNO)
			cSQL = cSQL + "AND I.ORDER_NO = '" + cORDERNO +"' AND !EMPTY(I.ORDER_NO) "
		ENDIF
		IF !EMPTY(cINVNO)
			cSQL = cSQL + "AND INV_NO = '" + cINVNO + "' AND !EMPTY(INV_NO) "
		ENDIF
		IF !EMPTY(cCHECK)
			cSQL = cSQL + "AND CHECK_NO = '" + cCHECK + "' AND !EMPTY(CHECK_NO) "
		ENDIF
		IF !EMPTY(cAMOUNT) AND EMPTY(cAMOUNTTO)
			cSQL = cSQL + "AND AMOUNT = " + ALLTRIM(cAMOUNT)+ " AND !EMPTY(AMOUNT) "
		ENDIF		
		IF !EMPTY(cAMOUNT) AND !EMPTY(cAMOUNTTO)
			cSQL = cSQL + "AND AMOUNT BETWEEN " + ALLTRIM(cAMOUNT) + " AND " + ALLTRIM(cAMOUNTTO)
		ENDIF	
		
		cSQL = cSQL + " ORDER BY "+cSortColumn + " " + cSORTORDER + " " + " INTO CURSOR X" 			 				
	
RETURN cSQL
ENDPROC


PROCEDURE PaymentSearchSQL  
	LPARAMETERS cCOID, cCONAME ,cORDERNO, cINVNO, cPONO, cCHECKFROM, cCHECKTO, cCHECKNO, cTYPE, cSORTCOLUMN, cSORTORDER   
	SET EXACT OFF	
	 		 	
	 	IF EMPTY(cCHECKFROM) AND EMPTY(cCHECKNO)
	 			
				cSQL = "SELECT I.CO_ID, I.CO_NAME, I.INV_NO, I.ORDER_NO, I.PO_NO, A.AMOUNT, A.AMOUNT - A.AMT_PAID, '' " +   ;
		        	"FROM COMPANY C, INVOICE I, AMOUNT A  WHERE NOT DELETED() and C.CO_ID = I.CO_ID and I.ORDER_NO = A.ORDER_NO  " + ;
		           	"AND I.INV_NO != 'DROP SHIP' AND  I.ORDR_CODE != '5' AND I.INV_DATE >= CTOD('1/1/2002') "         	  	
		        
		        IF cTYPE = "NOTPAID"
		        	cSQL = cSQL + "AND EMPTY(PAID_DATE) "
		        ENDIF   
		        IF !EMPTY(cCOID)
					cSQL = cSQL + "AND I.CO_ID = '" + cCOID +"' AND !EMPTY(I.CO_ID) "
				ENDIF				
				IF !EMPTY(cCONAME)
					cSQL = cSQL + 'AND I.CO_NAME = "' + cCONAME +'" AND !EMPTY(I.CO_NAME) '
				ENDIF
				IF !EMPTY(cORDERNO)
					cSQL = cSQL + "AND I.ORDER_NO = '" + cORDERNO +"' AND !EMPTY(I.ORDER_NO) "
				ENDIF
				IF !EMPTY(cINVNO)
					cSQL = cSQL + "AND INV_NO = '" + cINVNO + "' AND !EMPTY(INV_NO) "
				ENDIF
				IF !EMPTY(cPONO)
					cSQL = cSQL + "AND I.PO_NO = '" + cPONO + "' AND !EMPTY(PO_NO) "
				ENDIF
													
				cSQL = cSQL + " ORDER BY "+cSortColumn + " " + cSORTORDER + " " + " INTO CURSOR X" 		
				
		ELSE 
			   cSQL = "SELECT I.CO_ID, I.CO_NAME, I.INV_NO, I.ORDER_NO, I.PO_NO, A.AMOUNT, A.AMOUNT - A.AMT_PAID, CHECK_TOTL " +   ;
			       	"FROM INVOICE I, AMOUNT A, PAY_DTL P WHERE NOT DELETED() and I.ORDER_NO = A.ORDER_NO AND A.ORDER_NO = P.ORDER_NO " + ;
		           	"AND I.INV_NO != 'DROP SHIP' AND  I.ORDR_CODE != '5' AND I.INV_DATE >= CTOD('1/1/2002') "           
		        		        
		        IF cTYPE = "NOTPAID"
		        	cSQL = cSQL + "AND EMPTY(PAID_DATE) "
		        ENDIF        		
		        IF !EMPTY(cCOID)
					cSQL = cSQL + "AND I.CO_ID = '" + cCOID +"' AND !EMPTY(I.CO_ID) "
				ENDIF				
				IF !EMPTY(cCONAME)
					cSQL = cSQL + 'AND I.CO_NAME = "' + cCONAME +'" AND !EMPTY(I.CO_NAME) '
				ENDIF
				IF !EMPTY(cORDERNO)
					cSQL = cSQL + "AND I.ORDER_NO = '" + cORDERNO +"' AND !EMPTY(I.ORDER_NO) "
				ENDIF
				IF !EMPTY(cINVNO)
					cSQL = cSQL + "AND INV_NO = '" + cINVNO + "' AND !EMPTY(INV_NO) "
				ENDIF
				IF !EMPTY(cPONO)
					cSQL = cSQL + "AND PO_NO = '" + cPONO + "' AND !EMPTY(PO_NO) "
				ENDIF
				IF !EMPTY(cCHECKFROM) AND EMPTY(cCHECKTO)
					cSQL = cSQL + "AND CHECK_TOTL = " + ALLTRIM(cCHECKFROM)+ " AND !EMPTY(CHECK_TOTL) "
				ENDIF		
				IF !EMPTY(cCHECKFROM) AND !EMPTY(cCHECKTO)
					cSQL = cSQL + "AND CHECK_TOTL BETWEEN " + ALLTRIM(cCHECKFROM) + " AND " + ALLTRIM(cCHECKTO)
				ENDIF	
				IF !EMPTY(cCHECKNO)
					cSQL = cSQL + "AND CHECK_NO = '" + cCHECKNO + "' AND !EMPTY(CHECK_NO) "
				ENDIF
						
				cSQL = cSQL + " ORDER BY "+cSortColumn + " " + cSORTORDER + " " + " INTO CURSOR X" 		
			
		ENDIF
	
RETURN cSQL
ENDPROC



PROCEDURE FINDCONTACT

	 	DEFINE WINDOW BIG FROM 2,2 TO 19,77 TITLE "CONTACT LIST - [F2] TO SELECT";
 		COLOR SCHEME 2
 		ON KEY LABEL F2 DO GET_KEY 
  		BROWSE FIELDS LAST_NAME:H="LAST NAME" ,;
  					  FRST_NAME:H="FIRST NAME":20  ,;
  					  TITLE:H="TITLE"         ;
  					  WINDOW BIG
 					  
ENDPROC

PROCEDURE FINDCOMMENT		
	 	DEFINE WINDOW BIG FROM 2,2 TO 19,77 TITLE "COMMENT LIST - [F2] TO SELECT";
 		COLOR SCHEME 2 		
 		ON KEY LABEL F2 DO GET_KEY_COMMENT 
  		BROWSE FIELDS COMMENT:H="COMMENT":50  ;
  		       WINDOW BIG
 				
ENDPROC


PROCEDURE GET_KEY 
		ON KEY LABEL F2
		SELECT CONTACTCURSOR
		STORE LAST_NAME TO LAST
		STORE FRST_NAME TO FIRST
		STORE EMAIL TO EML
		STORE FAX_ARCODE TO AREA
		STORE FAX_PHONE TO PHONE
		STORE AREA_CODE TO AREA_PHONE
		STORE PHONE_NO TO PHONENO
		USE 
							
		SELECT QUOTE_HEADER
		LOCATE FOR ALLTRIM(QUOTE_NO) == ALLTRIM(QUOTENO)
		FOUND = FOUND()
		REPLACE FRST_NAME WITH FIRST
		REPLACE LAST_NAME WITH LAST
		REPLACE EMAIL WITH EML
		REPLACE FAX_ARCODE WITH AREA
		REPLACE FAX_PHONE WITH PHONE
		REPLACE AREA_CODE WITH AREA_PHONE
		REPLACE PHONE_NO WITH PHONENO
	
		RELEASE WINDOW BIG
		RETURN	
		 
ENDPROC		 		

PROCEDURE GET_KEY_COMMENT
		
	SELECT COMMENTCURSOR
	STORE COMMENT TO cCOMMENTS
	
	USE	IN COMMENTCURSOR	
	SELECT QUOTE_HEADER
	LOCATE FOR ALLTRIM(QUOTE_NO) == ALLTRIM(QUOTENO)
	cComments = ALLTRIM(quote_header.comments) + "  " + ALLTRIM(cCOMMENTS)
	REPLACE COMMENTS WITH ALLTRIM(cCOMMENTS)
		
	RETURN
	
ENDPROC	


PROCEDURE Get_Tax 
	LPARAMETERS nFreight
	DIMENSION nSubTotal(1), nTaxTotal(1)
			
	nSubTotal(1) = 0
	nTaxTotal(1) = 0
	
	**Do Calcs
		
	SELECT SUM(total_cost) FROM QUOTE_DETAIL WHERE ALLTRIM(quote_no) == ALLTRIM(QUOTENO) AND !DELETED() INTO ARRAY nSubTotal
	SELECT SUM(TOTAL_COST) FROM QUOTE_DETAIL WHERE ALLTRIM(quote_no) == ALLTRIM(QUOTENO) AND !DELETED() AND TAXABLE = "Y" INTO ARRAY nTaxTotal

	SELECT 2
	LOCATE FOR ALLTRIM(quote_no) == ALLTRIM(quoteno)
	FOUND = FOUND()
	REPLACE sub_total WITH nSubTotal(1)

	USE TAX_CODE SHARED IN 6
	SELECT 6
	
	LOCATE FOR TAX_CODE=TAX_CD
	IF FOUND()
		STORE TAX_AMOUNT TO TAX_RT
		T_RATE=TAX_RT*100
	ELSE
		T_RATE = 0
		TAX_RT=0
	ENDIF

	SELECT 2
	LOCATE FOR ALLTRIM(quote_no) == ALLTRIM(quoteno)
	FOUND = FOUND()
	nTAX = nTaxTotal(1) * TAX_RT
	REPLACE TAXES WITH nTax
	REPLACE TAX_RATE WITH T_RATE
	
	nTotal = nSubTotal(1) +  nTax + nFreight
	REPLACE Total WITH nTotal 
ENDPROC	
	





				  

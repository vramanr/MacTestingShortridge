PARAMETERS cYear

SET DEFAULT TO w:\foxapps2\foxapp\shrtridg 
*SET DEFAULT TO c:\foxapps\shrtridg

SELECT PARTSLST.PART_NO, SUM(QUANT) ;
FROM PARTSLST LEFT OUTER JOIN ORDETAIL ON PARTSLST.PART_NO = ORDETAIL.PART, INVOICE ;
WHERE INVOICE.ORDER_NO = ORDETAIL.ORDER_NO AND INVOICE.CO_ID = ORDETAIL.CO_ID ;
AND YEAR(INV_DATE) = CYEAR AND !DELETED() GROUP BY PART_NO;
UNION;
SELECT PARTSLST.PART_NO, 0;
FROM PARTSLST WHERE !DELETED() AND PART_NO NOT IN (SELECT PART FROM ORDETAIL, INVOICE WHERE ORDETAIL.ORDER_NO = INVOICE.ORDER_NO AND YEAR(INV_DATE) = CYEAR);
ORDER BY 1 INTO CURSOR EXPORT

COPY TO c:\windows\desktop\YTDSALES.dat DELIMITED WITH '"'

MESSAGEBOX("File YTDSALES.dat created on Desktop.", 0)
CLOSE ALL



SELECT *;
 FROM PRECHECK;
 WHERE PRECHECK.ADM_PRINT <> "Y";
   AND DELETED() <> .T.;
   AND PRECHECK.METER = "V";
   AND EMPTY(PRECHECK.RCL_FINISH);
   OR (EMPTY(PRECHECK.RP_FINISH) ;
   AND UPPER(PRECHECK.ADM_PRINT) <> UPPER("Y");
   AND DELETED() <> .T.;
   AND PRECHECK.METER = "V");
 ORDER BY PRECHECK.ORDER_NO;
 INTO CURSOR RPTAN
REPORT FORM REPAIRS\RPTAN.FRX TO PRINTER PROMPT PREVIEW


